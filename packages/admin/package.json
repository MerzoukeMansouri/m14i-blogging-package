    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "rehype-stringify": "^10.0.0",
    "unified": "^11.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
