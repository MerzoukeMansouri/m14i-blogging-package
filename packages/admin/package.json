  "type": "module",
  "description": "Full-featured blog CMS with WYSIWYG editor, drag & drop layouts, and AI content generation",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "blog",
    "cms",
    "admin",
    "wysiwyg",
    "drag-and-drop",
    "react",
    "nextjs"
  ],
  "author": "M14I",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MerzoukeMansouri/m14i-blogging-package.git",
    "directory": "packages/admin"
  },
  "peerDependencies": {
    "@hello-pangea/dnd": "^16.0.0",
