# =============================================================================
# m14i-blogging Example — Environment Variables
# =============================================================================
# Copy this file to .env and customize as needed.
# Pre-generated JWT keys below are for LOCAL DEVELOPMENT ONLY.
# DO NOT use these in production!
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# External ports (host-side, change if conflicts)
POSTGRES_EXTERNAL_PORT=54322
KONG_HTTP_PORT=54321
KONG_HTTPS_PORT=54323

# -----------------------------------------------------------------------------
# JWT — Pre-generated for local dev (DO NOT USE IN PRODUCTION)
# Secret and keys are HMAC-SHA256 signed and match each other.
# -----------------------------------------------------------------------------
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# Anon key — role: anon (public, limited access)
# Payload: {"role":"anon","iss":"supabase","iat":1735689600,"exp":1893456000}
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzM1Njg5NjAwLCJleHAiOjE4OTM0NTYwMDB9.GWGiTSNgBKqLp8TcgvmXMAQ46PbjA9-F4PZx7eVYedU

# Service role key — role: service_role (admin, bypass RLS)
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3MzU2ODk2MDAsImV4cCI6MTg5MzQ1NjAwMH0.JtfSe10EKI2xX10i4LG9WebD_1jt3x1eQaPiFWVWsds

# -----------------------------------------------------------------------------
# API / Kong
# -----------------------------------------------------------------------------
API_EXTERNAL_URL=http://localhost:54321
SUPABASE_PUBLIC_URL=http://localhost:54321

# -----------------------------------------------------------------------------
# GoTrue (Auth)
# -----------------------------------------------------------------------------
GOTRUE_JWT_SECRET=${JWT_SECRET}
GOTRUE_JWT_EXP=3600
GOTRUE_DB_DRIVER=postgres
GOTRUE_DB_DATABASE_URL=postgres://supabase_auth_admin:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
GOTRUE_SITE_URL=http://localhost:3000
GOTRUE_URI_ALLOW_LIST=
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_EXTERNAL_EMAIL_ENABLED=true
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_SMS_AUTOCONFIRM=true

# -----------------------------------------------------------------------------
# PostgREST
# -----------------------------------------------------------------------------
PGRST_DB_URI=postgres://authenticator:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
PGRST_DB_SCHEMAS=public,blog
PGRST_DB_ANON_ROLE=anon
PGRST_JWT_SECRET=${JWT_SECRET}
PGRST_DB_MAX_ROWS=1000

# -----------------------------------------------------------------------------
# Studio (Dashboard)
# -----------------------------------------------------------------------------
STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
STUDIO_PORT=3001
SUPABASE_STUDIO_PORT=3001
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=supabase

# -----------------------------------------------------------------------------
# Storage & Image Transformations
# -----------------------------------------------------------------------------
IMGPROXY_ENABLE_WEBP_DETECTION=true

# -----------------------------------------------------------------------------
# Next.js App (copy these to app/.env.local)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzM1Njg5NjAwLCJleHAiOjE4OTM0NTYwMDB9.GWGiTSNgBKqLp8TcgvmXMAQ46PbjA9-F4PZx7eVYedU
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3MzU2ODk2MDAsImV4cCI6MTg5MzQ1NjAwMH0.JtfSe10EKI2xX10i4LG9WebD_1jt3x1eQaPiFWVWsds
