{
  "name": "m14i-blogging",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo for @m14i/blogging-* packages - Drag & drop blog builder with customizable layouts and content blocks for React and Next.js",
  "scripts": {
    "build": "pnpm --filter @m14i/blogging-core build && pnpm --filter @m14i/blogging-server build && pnpm --filter @m14i/blogging-admin build",
    "build:core": "pnpm --filter @m14i/blogging-core build",
    "build:admin": "pnpm --filter @m14i/blogging-admin build",
    "build:server": "pnpm --filter @m14i/blogging-server build",
    "dev:packages": "pnpm --filter @m14i/blogging-core dev & pnpm --filter @m14i/blogging-server dev & pnpm --filter @m14i/blogging-admin dev",
    "dev:example": "pnpm --filter m14i-blogging-example dev",
    "clean": "rm -rf packages/*/dist example/app/.next",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "release": "pnpm build && pnpm -r --workspace-concurrency=1 exec -- npx --no-install semantic-release -e semantic-release-monorepo"
  },
  "keywords": [
    "blog",
    "builder",
    "cms",
    "drag-and-drop",
    "react",
    "nextjs",
    "next.js",
    "seo",
    "markdown",
    "tailwindcss"
  ],
  "author": "M14I",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MerzoukeMansouri/m14i-blogging-package.git"
  },
  "bugs": {
    "url": "https://github.com/MerzoukeMansouri/m14i-blogging-package/issues"
  },
  "homepage": "https://github.com/MerzoukeMansouri/m14i-blogging-package#readme",
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    }
  },
  "devDependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/builder-vite": "^10.3.4",
    "@storybook/react": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@storybook/test": "^8.6.15",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.48.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@toon-format/toon": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.4",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "semantic-release": "^25.0.3",
    "semantic-release-monorepo": "^8.0.2",
    "storybook": "^10.3.4",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
