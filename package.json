    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "lucide-react": "^1.7.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
