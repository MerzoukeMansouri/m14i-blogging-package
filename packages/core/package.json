{
  "name": "@m14i/blogging-core",
  "version": "1.0.0",
  "type": "module",
  "description": "Zero-dependency blog rendering and data layer - React components for displaying blog content",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.cjs"
    },
    "./public": {
      "types": "./dist/public/index.d.ts",
      "import": "./dist/public/index.mjs",
      "require": "./dist/public/index.cjs"
    },
    "./styles": "./dist/index.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "blog",
    "react",
    "nextjs",
    "cms",
    "seo",
    "supabase"
  ],
  "author": "M14I",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MerzoukeMansouri/m14i-blogging-package.git",
    "directory": "packages/core"
  },
  "peerDependencies": {
    "lucide-react": "^0.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^15.0.0",
    "recharts": "^2.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "unified": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    },
    "@supabase/ssr": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react-markdown": {
      "optional": true
    },
    "remark-gfm": {
      "optional": true
    },
    "unified": {
      "optional": true
    },
    "remark-parse": {
      "optional": true
    },
    "remark-rehype": {
      "optional": true
    },
    "rehype-stringify": {
      "optional": true
    },
    "react-syntax-highlighter": {
      "optional": true
    },
    "recharts": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "lucide-react": "^1.7.0",
    "next": "^15.5.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^3.8.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "unified": "^11.0.5"
  }
}
